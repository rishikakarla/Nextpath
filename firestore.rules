rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Content (coding problems, assessment, roadmap, daily tasks, aptitude topics)
    // Any logged-in user can read; only the admin can write
    match /content/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == 'kakarlarishi5124@gmail.com';
    }

    // Users — own doc: full access; any authenticated user can read (needed for mentor portal)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard — all logged-in users can read; each user writes only their own entry
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Daily Leaderboard — all logged-in users can read; each user writes only their own entry
    match /dailyLeaderboard/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.uid;
    }

    // Mentors — any logged-in user can read (for role detection on login)
    // Only admin can create / delete mentor entries
    match /mentors/{mentorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == 'kakarlarishi5124@gmail.com';
    }

    // Feedback — any authenticated user can read (mentors need to read all students' feedback)
    // Students see only their own feedback (enforced at app level in MentorFeedback page)
    match /feedback/{studentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
