rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Content (coding problems, assessment, roadmap, daily tasks, aptitude topics)
    // Any logged-in user can read; only the admin can write
    match /content/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.token.email == 'kakarlarishi5124@gmail.com';
    }

    // Users — each user can only read and write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Leaderboard — all logged-in users can read; each user writes only their own entry
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}